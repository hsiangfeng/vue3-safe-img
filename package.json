{
  "name": "vue3-safe-img",
  "version": "0.1.0",
  "description": "Vue 3 image fallback with optional YouTube-style blurred backdrop. Ships a v-safe-img directive, a <SafeImg> component, and a useSafeImg composable.",
  "license": "MIT",
  "author": "hsiangfeng <israynotarray@gmail.com>",
  "homepage": "https://github.com/hsiangfeng/vue3-safe-img#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hsiangfeng/vue3-safe-img.git"
  },
  "bugs": {
    "url": "https://github.com/hsiangfeng/vue3-safe-img/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "README.zh-TW.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit",
    "dev": "pnpm --filter playground dev"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.0"
  },
  "packageManager": "pnpm@9.15.0",
  "keywords": [
    "vue",
    "vue3",
    "image",
    "fallback",
    "broken-image",
    "placeholder",
    "blurred-backdrop",
    "echo-pillarboxing",
    "safe-image",
    "directive"
  ]
}
